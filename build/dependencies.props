<Project>

  <PropertyGroup Label="SDK Versions">
    <LangVersion>latest</LangVersion>
  </PropertyGroup>

  <PropertyGroup Label="Reproducible build">
    <Deterministic>true</Deterministic>
    <!-- Normalizes paths inside .pdb/.dll on CI for reproducible output -->
    <ContinuousIntegrationBuild Condition="'$(GITHUB_ACTIONS)' == 'true'">true</ContinuousIntegrationBuild>
  </PropertyGroup>

  <PropertyGroup Label="Package information">
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageProjectUrl>https://github.com/groupdocs-metadata/GroupDocs.Metadata.Mcp</PackageProjectUrl>
    <RepositoryUrl>https://github.com/groupdocs-metadata/GroupDocs.Metadata.Mcp</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <Authors>GroupDocs Contributors</Authors>
    <Company>Aspose</Company>
    <Copyright>Copyright © Aspose Pty Ltd $([System.DateTime]::Now.Year)</Copyright>
    <PublishRepositoryUrl>true</PublishRepositoryUrl>
    <EmbedUntrackedSources>true</EmbedUntrackedSources>
    <AllowedOutputExtensionsInPackageBuildOutputFolder>true</AllowedOutputExtensionsInPackageBuildOutputFolder>
  </PropertyGroup>

  <PropertyGroup Label="Package Versions">
    <GroupDocsMetadataMcp>26.5.1</GroupDocsMetadataMcp>
  </PropertyGroup>

  <PropertyGroup Label="External Dependency Versions">
    <GroupDocsMcpCore>26.4.1</GroupDocsMcpCore>
    <GroupDocsMetadata>26.1.0</GroupDocsMetadata>
    <MicrosoftExtensionsHosting>10.0.5</MicrosoftExtensionsHosting>
    <ModelContextProtocol>1.1.0</ModelContextProtocol>
    <MicrosoftSourceLinkGithub>8.0.0</MicrosoftSourceLinkGithub>
    <!-- Must match the SkiaSharp version $(GroupDocsMetadata) transitively pulls. Re-verify after every GroupDocsMetadata bump (ABI-incompatible otherwise). -->
    <SkiaSharp>3.119.0</SkiaSharp>
  </PropertyGroup>

  <PropertyGroup Label="NuGet Common Settings">
    <PackageReleaseNotes>https://github.com/groupdocs-metadata/GroupDocs.Metadata.Mcp/releases/tag/$(GroupDocsMetadataMcp)</PackageReleaseNotes>
  </PropertyGroup>

</Project>
